# Clerk Authentication
# Get these from your Clerk Dashboard > JWT Templates > Create "convex" template
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Google OAuth (for Drive API)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# AssemblyAI (for transcription)
# Get from https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# OpenAI (for extraction)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (for section generation)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# AI Models
# Update these values to switch models without touching code
MODEL_EXTRACTION=gpt-5.4
MODEL_SYNTHESIS=gpt-5.4
MODEL_SECTION_WRITER=claude-opus-4-6
MODEL_SECTION_REVIEWER=claude-opus-4-6

# Webhook Security (required, generate a random string)
WEBHOOK_SECRET=your-random-webhook-secret

# Convex Site URL (set automatically in production)
# For local development, leave empty or set to your ngrok URL for webhook testing
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Public site URL used to resolve auth redirects
SITE_URL=http://localhost:3000

# Redirect allowlist (comma-separated origins, in addition to SITE_URL origin)
# Example: REDIRECT_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
REDIRECT_ALLOWED_ORIGINS=

# Google Cloud Storage (for handling large files >95MB)
# Create a service account with Storage Object Admin role on your bucket
# Download the JSON key file and extract these values
GCS_BUCKET_NAME=your-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GCS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
