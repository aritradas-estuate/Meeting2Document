# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_NAME=MeetingsToDocument
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================
# SERVER SETTINGS
# ============================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql+asyncpg://mtd_user:mtd_password@localhost:5432/meetingstodoc

# ============================================================
# REDIS (for Celery)
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# GOOGLE OAUTH & DRIVE
# ============================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ============================================================
# AI MODEL API KEYS
# ============================================================
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key
ASSEMBLYAI_API_KEY=your-assemblyai-key

# ============================================================
# AI MODEL CONFIGURATION (Easily Changeable)
# ============================================================
MODEL_VIDEO_ANALYSIS=gemini-3-flash
MODEL_TRANSCRIPTION=best
MODEL_EXTRACTION=gpt-5.2
MODEL_SYNTHESIS=gpt-5.2
MODEL_SECTION_WRITER=gpt-5.2
MODEL_SECTION_REVIEWER=claude-3-5-sonnet-20241022

# ============================================================
# PROCESSING SETTINGS
# ============================================================
MAX_REVIEW_LOOPS=3
DEFAULT_DOCUMENT_SCHEMA=zuora_q2r

# Timeouts (in seconds)
TRANSCRIPTION_TIMEOUT=600
VIDEO_ANALYSIS_TIMEOUT=300
SYNTHESIS_TIMEOUT=120
SECTION_GENERATION_TIMEOUT=60

# ============================================================
# FILE STORAGE
# ============================================================
TEMP_FILE_DIR=/tmp/meetingstodoc
MAX_FILE_SIZE_MB=100

# ============================================================
# SECURITY
# ============================================================
SECRET_KEY=your-secret-key-at-least-32-characters-long-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================
# MONITORING (Optional)
# ============================================================
SENTRY_DSN=
